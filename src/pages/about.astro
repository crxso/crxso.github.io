---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { personal, skills, certifications, education } from "../data/resume";

/**
 * Fetch with retries + timeout. Used for all build-time external data fetches.
 * - Retries on network error OR non-2xx status.
 * - Timeout cancels each attempt via AbortController.
 * - Small backoff between attempts (500ms, 1000ms, 2000ms).
 * Returns the Response on success, null after all retries fail.
 */
async function fetchWithRetry(
  url: string,
  options: RequestInit = {},
  attempts = 3,
  timeoutMs = 10000,
): Promise<Response | null> {
  for (let i = 0; i < attempts; i++) {
    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), timeoutMs);
    try {
      const res = await fetch(url, { ...options, signal: ctrl.signal });
      clearTimeout(timer);
      if (res.ok) return res;
      console.warn(`[build] fetch ${url} → HTTP ${res.status} (attempt ${i + 1}/${attempts})`);
    } catch (err: any) {
      clearTimeout(timer);
      console.warn(`[build] fetch ${url} failed: ${err?.message || err} (attempt ${i + 1}/${attempts})`);
    }
    if (i < attempts - 1) {
      await new Promise((r) => setTimeout(r, 500 * Math.pow(2, i))); // 500ms, 1000ms, 2000ms
    }
  }
  return null;
}

// Build-time fetch of GitHub contribution calendar (no auth needed)
type Day = { date: string; count: number; level: 0 | 1 | 2 | 3 | 4 };
let contributions: Day[] = [];
let totalContributions = 0;
{
  const res = await fetchWithRetry("https://github-contributions-api.jogruber.de/v4/crxso?y=last");
  if (!res) {
    // CRITICAL: last-year heatmap is the main UI — abort the build rather than deploy a broken page.
    throw new Error("[build] jogruber API (y=last) unreachable after retries — aborting build to avoid empty GitHub section.");
  }
  const data = await res.json();
  contributions = data.contributions || [];
  totalContributions = data.total?.lastYear ?? contributions.reduce((s: number, d: Day) => s + d.count, 0);
  // Abort only if the response is malformed (fewer than ~300 days of data for a full year window).
  // A quiet day with 0 commits is totally fine — we check the number of DAYS returned, not commit counts.
  if (contributions.length < 300) {
    throw new Error(`[build] jogruber API returned only ${contributions.length} days — malformed response, aborting build.`);
  }
}

// Build-time fetch of all-time contributions for Total / Current / Longest streak stats
let allYears: Day[] = [];
let lifetimeTotal = 0;
let firstContributionDate = "";
let currentStreak = { length: 0, start: "", end: "" };
let longestStreak = { length: 0, start: "", end: "" };
{
  const res = await fetchWithRetry("https://github-contributions-api.jogruber.de/v4/crxso?y=all");
  if (!res) {
    throw new Error("[build] jogruber API (y=all) unreachable after retries — aborting build to avoid missing streak stats.");
  }
  {
    const data = await res.json();
    // NOTE: jogruber returns contributions in DESC order (newest first). Sort ASC
    // so "latest" is at the end and streak math is straightforward.
    allYears = (data.contributions || []).slice().sort((a: Day, b: Day) => a.date.localeCompare(b.date));
    if (data.total && typeof data.total === "object") {
      lifetimeTotal = Object.values(data.total).reduce((a: number, b: any) => a + (typeof b === "number" ? b : 0), 0);
    } else {
      lifetimeTotal = allYears.reduce((s, d) => s + d.count, 0);
    }
    const firstDay = allYears.find((d) => d.count > 0);
    firstContributionDate = firstDay?.date || "";

    // Current streak: walk backward from the latest day.
    // If the very latest day has no contributions (common mid-day), allow the
    // streak to end on the most recent day that DOES have contributions.
    let endIdx = allYears.length - 1;
    while (endIdx >= 0 && allYears[endIdx].count === 0) endIdx--;
    if (endIdx >= 0) {
      let len = 1;
      let start = allYears[endIdx].date;
      const end = allYears[endIdx].date;
      for (let j = endIdx - 1; j >= 0; j--) {
        if (allYears[j].count > 0) {
          len++;
          start = allYears[j].date;
        } else break;
      }
      currentStreak = { length: len, start, end };
    }

    // Longest streak: scan forward tracking max consecutive run.
    let run = 0;
    let runStart = "";
    for (const d of allYears) {
      if (d.count > 0) {
        if (run === 0) runStart = d.date;
        run++;
        if (run > longestStreak.length) {
          longestStreak = { length: run, start: runStart, end: d.date };
        }
      } else {
        run = 0;
      }
    }
  }
}

// Format an ISO date like "2019-01-16" -> "1.16.19"
function fmtDate(iso: string): string {
  if (!iso) return "";
  const [y, m, d] = iso.split("-");
  return `${Number(m)}.${Number(d)}.${y.slice(-2)}`;
}

// Build-time fetch of top languages across ALL repos (public + private) via GraphQL
type Lang = { name: string; color: string; size: number; pct: number };
let topLanguages: Lang[] = [];
const GH_TOKEN = import.meta.env.GH_STATS_TOKEN || process.env.GH_STATS_TOKEN;
if (GH_TOKEN) {
  try {
    // Repos to exclude from language stats — loaded from the GH_EXCLUDE_REPOS env var
    // (comma-separated, case-insensitive). Keeps the excluded list out of source control.
    // Local: add to site/.env      e.g.  GH_EXCLUDE_REPOS=foo,bar-baz
    // Prod:  add as a repo secret  with the same name, then reference it in deploy.yml.
    const excludeRaw = import.meta.env.GH_EXCLUDE_REPOS || process.env.GH_EXCLUDE_REPOS || "";
    const EXCLUDE_REPOS = new Set<string>(
      excludeRaw.split(",").map((n: string) => n.trim().toLowerCase()).filter(Boolean)
    );

    const query = `
      query($after: String) {
        viewer {
          repositories(first: 100, after: $after, ownerAffiliations: OWNER, isFork: false, isArchived: false) {
            pageInfo { hasNextPage endCursor }
            nodes {
              name
              languages(first: 20, orderBy: {field: SIZE, direction: DESC}) {
                edges { size node { name color } }
              }
            }
          }
        }
      }`;
    const totals = new Map<string, { color: string; size: number }>();
    let after: string | null = null;
    for (let i = 0; i < 10; i++) {
      const r = await fetchWithRetry("https://api.github.com/graphql", {
        method: "POST",
        headers: {
          "Authorization": `bearer ${GH_TOKEN}`,
          "Content-Type": "application/json",
          "User-Agent": "crxso-site-build",
        },
        body: JSON.stringify({ query, variables: { after } }),
      });
      if (!r) break;
      const j: any = await r.json();
      const repos = j?.data?.viewer?.repositories;
      if (!repos) break;
      for (const repo of repos.nodes || []) {
        if (repo?.name && EXCLUDE_REPOS.has(repo.name.toLowerCase())) continue;
        for (const edge of repo.languages?.edges || []) {
          const name = edge.node.name;
          const prev = totals.get(name) || { color: edge.node.color || "#858585", size: 0 };
          prev.size += edge.size;
          totals.set(name, prev);
        }
      }
      if (!repos.pageInfo?.hasNextPage) break;
      after = repos.pageInfo.endCursor;
    }
    const grand = Array.from(totals.values()).reduce((s, v) => s + v.size, 0) || 1;
    topLanguages = Array.from(totals.entries())
      .map(([name, v]) => ({ name, color: v.color, size: v.size, pct: (v.size / grand) * 100 }))
      .sort((a, b) => b.size - a.size)
      .slice(0, 8);
  } catch (e) {
    topLanguages = [];
  }
}

// Group into weeks (columns of 7) aligned by day-of-week
const firstDow = contributions.length ? new Date(contributions[0].date).getUTCDay() : 0;
const padded: (Day | null)[] = Array(firstDow).fill(null).concat(contributions);
const weeks: (Day | null)[][] = [];
for (let i = 0; i < padded.length; i += 7) weeks.push(padded.slice(i, i + 7));

// Month labels (show month when week's first day is in a new month)
const monthLabels = weeks.map((w, i) => {
  const d = w.find((x) => x) as Day | undefined;
  if (!d) return "";
  const m = new Date(d.date).getUTCMonth();
  const prev = i > 0 ? (weeks[i - 1].find((x) => x) as Day | undefined) : undefined;
  const pm = prev ? new Date(prev.date).getUTCMonth() : -1;
  return m !== pm ? new Date(d.date).toLocaleDateString("en-US", { month: "short", timeZone: "UTC" }) : "";
});
---

<Layout title="About | Cristian Ornelas">
  <section class="pt-24 md:pt-32 pb-10 md:pb-16 transition-colors duration-300" style="background: var(--bg-primary);">
    <div class="max-w-7xl mx-auto px-6">
      <div class="reveal">
        <span class="text-[13px] md:text-[15px] font-semibold tracking-[0.1em] uppercase" style="color: var(--accent);">About</span>
        <h1 class="text-[clamp(1.5rem,5vw,3rem)] font-bold mt-2 mb-2" style="color: var(--text-primary);">Security-first engineer<br />with an adversarial mindset.</h1>
        <div class="w-10 h-0.5 rounded-full mt-4" style="background: var(--accent);"></div>
      </div>
    </div>
  </section>

  <!-- Bio -->
  <section class="pb-10 md:pb-16 transition-colors duration-300" style="background: var(--bg-primary);">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-[1.4fr_1fr] gap-8 md:gap-14">
        <div>
          <p class="reveal text-base md:text-lg font-medium leading-relaxed mb-4 md:mb-5" style="color: var(--text-primary);">{personal.summary}</p>
          <p class="reveal stagger-1 text-[13px] md:text-[15px] mb-3 md:mb-4" style="color: var(--text-secondary);">From engineering automated AppSec tooling that reduced manual processes to minutes at TikTok, to leading large-scale incident response and deploying SAST/DAST in Kubernetes clusters, I operate at the intersection of security and software engineering.</p>
          <p class="reveal stagger-2 text-[13px] md:text-[15px]" style="color: var(--text-secondary);">My career progression from infrastructure security through vulnerability management to application security reflects a deliberate path toward understanding systems from every layer of the stack.</p>
        </div>
        <div class="reveal stagger-3">
          <div class="rounded-2xl border p-4 md:p-6 card-hover" style="background: var(--card-bg); border-color: var(--border);">
            <h3 class="text-[13px] md:text-[15px] font-semibold tracking-[0.1em] uppercase mb-3 md:mb-4" style="color: var(--accent);">Focus Areas</h3>
            <div class="flex flex-col gap-2 md:gap-2.5">
              {["Application Security", "Tooling & Automation", "Vulnerability Management at Scale", "Cloud Container Security", "Micro-Service Architecture", "DevSecOps", "AI/ML Security", "Threat Modeling & Secure Design Reviews", "Incident Response & Forensics"].map((f) => (
                <div class="flex items-center gap-2.5 text-[13px] md:text-[15px]" style="color: var(--text-secondary);">
                  <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background: var(--accent);"></span>
                  {f}
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="py-10 md:py-16 transition-colors duration-300" style="background: var(--bg-secondary);">
    <div class="max-w-7xl mx-auto px-6">
      <div class="reveal mb-5 md:mb-8">
        <span class="text-[13px] md:text-[15px] font-semibold tracking-[0.1em] uppercase" style="color: var(--accent);">Skills</span>
        <h2 class="text-xl md:text-2xl font-bold mt-2" style="color: var(--text-primary);">Technical Skills</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-3">
        {skills.map((skill, i) => (
          <div class={`reveal stagger-${Math.min(i+1, 8)} rounded-2xl border p-4 md:p-5 card-hover`} style="background: var(--card-bg); border-color: var(--border);">
            <h3 class="text-[13px] md:text-[15px] font-semibold tracking-[0.06em] uppercase mb-2 md:mb-3" style="color: var(--accent);">{skill.category}</h3>
            <div class="flex flex-wrap gap-1.5">
              {skill.items.map((item) => (
                <span class="font-[family-name:var(--font-mono)] text-[13px] md:text-[15px] px-2 py-0.5 rounded-md" style="background: var(--bg-tertiary); color: var(--text-secondary);">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GitHub -->
  <section class="py-10 md:py-16 transition-colors duration-300" style="background: var(--bg-primary);">
    <div class="max-w-7xl mx-auto px-6">
      <div class="reveal mb-5 md:mb-8 flex items-end justify-between flex-wrap gap-2">
        <div>
          <span class="text-[13px] md:text-[15px] font-semibold tracking-[0.1em] uppercase" style="color: var(--accent);">GitHub</span>
          <h2 class="text-xl md:text-2xl font-bold mt-2" style="color: var(--text-primary);">Open Source &amp; Activity</h2>
        </div>
        <a href="https://github.com/crxso" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 text-[15px] font-medium px-3 py-1.5 rounded-md border transition-all hover:-translate-y-0.5" style="background: var(--bg-tertiary); color: var(--text-primary); border-color: var(--border);">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          @crxso
        </a>
      </div>

      <!-- Streak + Top Languages -->
      <div class="grid md:grid-cols-2 gap-4 mb-4">
        <div class="reveal stagger-1 rounded-2xl border p-4 md:p-5 card-hover" style="background: var(--card-bg); border-color: var(--border); min-height: 200px;">
          <div class="streak-card">
            <!-- Total -->
            <div class="streak-col">
              <div class="streak-num">{lifetimeTotal.toLocaleString()}</div>
              <div class="streak-label">Total Contributions</div>
              <div class="streak-range">{firstContributionDate ? `${fmtDate(firstContributionDate)} – Present` : ""}</div>
            </div>
            <!-- Current (center, ringed, Octocat) -->
            <div class="streak-col streak-center">
              <div class="streak-ring-wrap">
                <svg class="streak-ring" viewBox="0 0 120 120" aria-hidden="true">
                  <circle cx="60" cy="60" r="52" fill="none" stroke="var(--accent)" stroke-width="4" />
                </svg>
                <svg class="streak-octocat" width="22" height="22" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
                </svg>
                <div class="streak-ring-num">{currentStreak.length}</div>
              </div>
              <div class="streak-label streak-accent">Current Streak</div>
              <div class="streak-range">{currentStreak.length > 0 ? `${fmtDate(currentStreak.start)} – ${fmtDate(currentStreak.end)}` : "—"}</div>
            </div>
            <!-- Longest -->
            <div class="streak-col">
              <div class="streak-num">{longestStreak.length}</div>
              <div class="streak-label">Longest Streak</div>
              <div class="streak-range">{longestStreak.length > 0 ? `${fmtDate(longestStreak.start)} – ${fmtDate(longestStreak.end)}` : "—"}</div>
            </div>
          </div>
        </div>
        <div class="reveal stagger-2 rounded-2xl border p-4 md:p-5 card-hover" style="background: var(--card-bg); border-color: var(--border); min-height: 200px;">
          <h3 class="text-[15px] font-semibold tracking-[0.06em] uppercase mb-4" style="color: var(--accent);">Most Used Languages</h3>
          {topLanguages.length === 0 ? (
            <p class="text-[15px]" style="color: var(--text-muted);">Language data unavailable.</p>
          ) : (
            <>
              <div class="flex w-full h-2 rounded-full overflow-hidden mb-4" style="background: var(--bg-tertiary);">
                {topLanguages.map((l) => (
                  <div style={`width: ${l.pct}%; background: ${l.color};`} title={`${l.name} ${l.pct.toFixed(1)}%`}></div>
                ))}
              </div>
              <div class="grid grid-cols-2 gap-x-4 gap-y-1.5">
                {topLanguages.map((l) => (
                  <div class="flex items-center gap-2 text-[15px]" style="color: var(--text-secondary);">
                    <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style={`background: ${l.color};`}></span>
                    <span class="truncate">{l.name}</span>
                    <span class="ml-auto font-[family-name:var(--font-mono)]" style="color: var(--text-muted);">{l.pct.toFixed(1)}%</span>
                  </div>
                ))}
              </div>
            </>
          )}
        </div>
      </div>

      <!-- Contribution heatmap (self-rendered from GitHub data at build time) -->
      <div class="reveal stagger-3 rounded-2xl border p-4 md:p-5 card-hover" style="background: var(--card-bg); border-color: var(--border);">
        <div class="flex items-end justify-between flex-wrap gap-2 mb-4">
          <h3 class="text-[15px] font-semibold tracking-[0.06em] uppercase" style="color: var(--accent);">Contribution Activity</h3>
          <span class="text-[15px]" style="color: var(--text-muted);">
            <strong style="color: var(--text-primary);">{totalContributions.toLocaleString()}</strong> contributions in the last year
          </span>
        </div>
        <div class="gh-scroll">
          <div class="gh-heatmap" style={`--weeks: ${weeks.length};`}>
            <!-- Month labels -->
            <div class="gh-months">
              {monthLabels.map((m) => <span class="gh-month">{m}</span>)}
            </div>
            <div class="gh-body">
              <!-- Day-of-week labels -->
              <div class="gh-dow">
                <span></span>
                <span>Mon</span>
                <span></span>
                <span>Wed</span>
                <span></span>
                <span>Fri</span>
                <span></span>
              </div>
              <!-- Weeks grid -->
              <div class="gh-grid">
                {weeks.map((week) => (
                  <div class="gh-col">
                    {Array.from({ length: 7 }).map((_, i) => {
                      const d = week[i];
                      return <div class={`gh-cell gh-l${d ? d.level : 0}`} title={d ? `${d.count} contribution${d.count === 1 ? "" : "s"} on ${d.date}` : ""}></div>;
                    })}
                  </div>
                ))}
              </div>
            </div>
            <div class="gh-legend">
              <span>Less</span>
              <div class="gh-cell gh-l0"></div>
              <div class="gh-cell gh-l1"></div>
              <div class="gh-cell gh-l2"></div>
              <div class="gh-cell gh-l3"></div>
              <div class="gh-cell gh-l4"></div>
              <span>More</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-10 md:py-16 transition-colors duration-300" style="background: var(--bg-primary);">
    <div class="max-w-7xl mx-auto px-6">
      <div class="reveal mb-5 md:mb-8">
        <span class="text-[13px] md:text-[15px] font-semibold tracking-[0.1em] uppercase" style="color: var(--accent);">Certifications</span>
        <h2 class="text-xl md:text-2xl font-bold mt-2" style="color: var(--text-primary);">Credentials</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-3">
        {certifications.map((cert, i) => (
          <div class={`reveal stagger-${Math.min(i+1, 6)} flex items-center md:items-center gap-3 md:gap-4 rounded-2xl border p-3 md:p-4 card-hover`} style="background: var(--card-bg); border-color: var(--border);">
            <div class="w-9 h-9 md:w-10 md:h-10 rounded-xl flex items-center justify-center flex-shrink-0" style={`background: ${cert.status === "In Progress" ? "var(--color-yellow-soft)" : "var(--color-emerald-soft)"};`}>
              {cert.status === "In Progress" ? (
                <Icon name="lucide:clock" class="w-[16px] h-[16px] md:w-[18px] md:h-[18px]" style="color: var(--color-yellow);" />
              ) : (
                <Icon name="lucide:check-circle" class="w-[16px] h-[16px] md:w-[18px] md:h-[18px]" style="color: var(--color-emerald);" />
              )}
            </div>
            <div class="min-w-0 flex-1">
              <span class="block text-[13px] md:text-[15px] font-medium break-words md:truncate" style="color: var(--text-primary);">{cert.name}</span>
              <span class="block text-[13px] md:text-[15px]" style="color: var(--text-muted);">{cert.issuer}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style is:global>
    .gh-card-dark { display: none; }
    .gh-card-light { display: block; }
    .dark .gh-card-dark { display: block; }
    .dark .gh-card-light { display: none; }

    /* Custom streak card — replaces the heroku widget, uses Octocat instead of flame */
    .streak-card {
      display: grid;
      grid-template-columns: 1fr 1.15fr 1fr;
      gap: 1rem;
      align-items: center;
      width: 100%;
      padding: 0.5rem 0.25rem;
    }
    .streak-col {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.25rem;
    }
    .streak-num {
      font-family: var(--font-body);
      font-size: 2rem;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.1;
    }
    .streak-label {
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--text-secondary);
    }
    .streak-accent { color: var(--accent); font-weight: 600; }
    .streak-range {
      font-size: 0.8rem;
      color: var(--text-muted);
      font-family: var(--font-mono);
    }
    .streak-center { gap: 0.4rem; }
    .streak-ring-wrap {
      position: relative;
      width: 120px;
      height: 120px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 0.25rem;
    }
    .streak-ring { position: absolute; inset: 0; width: 100%; height: 100%; }
    .streak-ring-num {
      position: relative;
      font-family: var(--font-body);
      font-size: 2.25rem;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1;
    }
    .streak-octocat {
      position: absolute;
      top: -6px;
      left: 50%;
      transform: translateX(-50%);
      color: var(--accent);
      background: var(--card-bg);
      padding: 2px 4px;
      border-radius: 4px;
    }
    /* Mobile: stack columns */
    @media (max-width: 640px) {
      .streak-card { grid-template-columns: 1fr; gap: 1.5rem; }
      .streak-center { order: -1; }
    }

    /* Self-rendered contribution heatmap. Card scrolls horizontally on narrow viewports;
       on wider viewports cells scale up to fill the card (no wasted space, no overflow). */
    .gh-scroll { overflow-x: auto; overflow-y: hidden; width: 100%; }
    .gh-scroll::-webkit-scrollbar { height: 6px; }
    .gh-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    .gh-heatmap {
      font-family: var(--font-body);
      container-type: inline-size;
      /* Ideal cell size if we fill the card: (container - dow - body gap - (weeks-1)*gap) / weeks
         Clamp keeps it readable on narrow (min 11px -> triggers scroll) and capped on wide (max 14px). */
      --cell: max(11px, calc((100cqw - 28px - (var(--weeks) - 1) * 3px) / var(--weeks)));
      /* Min width guarantees horizontal scroll kicks in rather than squishing below 11px cells. */
      min-width: calc(28px + var(--weeks) * 11px + (var(--weeks) - 1) * 3px);
    }
    .gh-months { display: grid; grid-template-columns: repeat(var(--weeks), var(--cell)); gap: 3px; font-size: 11px; color: var(--text-muted); margin-bottom: 6px; margin-left: 28px; }
    .gh-month { height: 14px; white-space: nowrap; }
    .gh-body { display: flex; gap: 6px; }
    .gh-dow { display: grid; grid-template-rows: repeat(7, var(--cell)); gap: 3px; font-size: 11px; color: var(--text-muted); width: 22px; }
    .gh-dow span { display: flex; align-items: center; line-height: 1; }
    .gh-grid { display: grid; grid-template-columns: repeat(var(--weeks), var(--cell)); gap: 3px; }
    .gh-col { display: grid; grid-template-rows: repeat(7, var(--cell)); gap: 3px; }
    .gh-cell { width: var(--cell); height: var(--cell); border-radius: 2px; }
    .gh-legend { display: flex; align-items: center; gap: 4px; justify-content: flex-end; margin-top: 8px; font-size: 11px; color: var(--text-muted); }
    .gh-legend .gh-cell { width: 10px; height: 10px; }
    /* Light-mode cell levels (GitHub-like greens) */
    .gh-l0 { background: #EBEDF0; }
    .gh-l1 { background: #9BE9A8; }
    .gh-l2 { background: #40C463; }
    .gh-l3 { background: #30A14E; }
    .gh-l4 { background: #216E39; }
    /* Dark-mode cell levels */
    .dark .gh-l0 { background: #161B22; }
    .dark .gh-l1 { background: #0E4429; }
    .dark .gh-l2 { background: #006D32; }
    .dark .gh-l3 { background: #26A641; }
    .dark .gh-l4 { background: #39D353; }
  </style>

  <!-- Education -->
  <section class="py-10 md:py-16 transition-colors duration-300" style="background: var(--bg-secondary);">
    <div class="max-w-7xl mx-auto px-6">
      <div class="reveal mb-5 md:mb-8">
        <span class="text-[13px] md:text-[15px] font-semibold tracking-[0.1em] uppercase" style="color: var(--accent);">Education</span>
        <h2 class="text-xl md:text-2xl font-bold mt-2" style="color: var(--text-primary);">Background</h2>
      </div>
      <div class="reveal stagger-1 rounded-2xl border p-4 md:p-6 card-hover flex items-center gap-3 md:gap-5 flex-wrap" style="background: var(--card-bg); border-color: var(--border);">
        <div class="w-9 h-9 md:w-11 md:h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background: var(--accent-soft);">
          <Icon name="lucide:graduation-cap" class="w-[18px] h-[18px] md:w-[22px] md:h-[22px]" style="color: var(--accent);" />
        </div>
        <div class="flex-1">
          <h3 class="text-[15px] md:text-base font-semibold" style="color: var(--text-primary);">{education.school}</h3>
          <p class="text-[13px] md:text-[15px]" style="color: var(--text-secondary);">{education.degree}</p>
        </div>
        <div class="text-right flex-shrink-0">
          <span class="block text-[13px] md:text-[15px] font-medium" style="color: var(--accent);">{education.startDate} – {education.endDate}</span>
          <span class="block text-[13px] md:text-[15px]" style="color: var(--text-muted);">{education.location}</span>
        </div>
      </div>
    </div>
  </section>
</Layout>

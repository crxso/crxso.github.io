---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import { personal } from "../data/resume";
---

<Layout>
  <!-- Hero -->
  <section id="home-hero" class="min-h-[100dvh] md:min-h-screen flex items-center md:items-center transition-colors duration-300 relative overflow-hidden" style="background: var(--bg-primary);">
    <div class="max-w-7xl mx-auto px-6 pt-[80px] pb-8 md:py-32 w-full">
      <div>
        <!-- Badge -->
        <div class="reveal inline-flex items-center gap-2 text-[13px] md:text-[15px] font-semibold rounded-full px-3 md:px-3.5 py-1 md:py-1.5 mb-4 md:mb-8 border" style="background: var(--card-bg); color: var(--text-primary); border-color: var(--border); box-shadow: 0 2px 12px var(--accent-soft);">
          <span class="w-2 h-2 rounded-full animate-pulse" style="background: var(--accent); box-shadow: 0 0 8px var(--accent);"></span>
          Application Security Engineer
        </div>

        <!-- Name + Photo row -->
        <div class="flex items-start justify-between gap-6 md:gap-10 flex-wrap">
          <div class="max-w-xl flex-1">
            <!-- Mobile photo: inline with name -->
            <div class="flex items-center justify-between gap-3 md:hidden mb-4">
              <h1 id="home-name-mobile" class="reveal stagger-1 text-[clamp(1.75rem,8vw,2.75rem)] font-bold leading-[1.05] tracking-tight" style="color: var(--text-primary);">
                {personal.firstName}<br />
                <span style="color: var(--accent);">{personal.lastName}</span>
              </h1>
              <div class="reveal stagger-2 w-[7.5rem] h-[7.5rem] rounded-full overflow-hidden border-2 shadow-xl flex-shrink-0 ml-auto" style="border-color: var(--border);">
                <img src="/cristian.png" alt="Cristian Ornelas" class="w-full h-full object-cover" />
              </div>
            </div>

            <!-- Desktop name (no photo here) -->
            <h1 id="home-name-desktop" class="reveal stagger-1 hidden md:block text-[clamp(2.5rem,7vw,4.5rem)] font-bold leading-[1.1] tracking-tight mb-6" style="color: var(--text-primary);">
              {personal.firstName}<br />
              <span style="color: var(--accent);">{personal.lastName}</span>
            </h1>

            <div class="reveal stagger-2 flex items-center gap-2 md:gap-2.5 flex-wrap text-[13px] md:text-[15px] mb-4 md:mb-6">
              <a href="https://github.com/crxso" target="_blank" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md font-medium border transition-all hover:-translate-y-0.5" style="background: var(--bg-tertiary); color: var(--text-primary); border-color: var(--border);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                crxso
              </a>
              <a href="https://www.linkedin.com/in/cristianornelas/" target="_blank" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md font-medium border transition-all hover:-translate-y-0.5" style="background: var(--bg-tertiary); color: var(--text-primary); border-color: var(--border);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
            </div>

            <div class="reveal stagger-3 terminal-window max-w-xl mb-4 md:mb-8">
              <div class="terminal-bar">
                <span class="terminal-dot terminal-dot-red" aria-hidden="true"></span>
                <span class="terminal-dot terminal-dot-yellow" aria-hidden="true"></span>
                <span class="terminal-dot terminal-dot-green" aria-hidden="true"></span>
                <span class="terminal-title">~ — cristian@appsec</span>
              </div>
              <div class="terminal-body">
                <p class="terminal-line"><span class="terminal-prompt">$</span><span class="terminal-cmd">whoami</span></p>
                <p class="terminal-output">{personal.summary}<span class="terminal-cursor" aria-hidden="true">▋</span></p>
              </div>
            </div>

          </div>

          <!-- Desktop: Profile Photo -->
          <div class="reveal stagger-2 flex-shrink-0 hidden md:block md:mr-16 lg:mr-32">
            <div class="w-[18rem] h-[18rem] lg:w-[22rem] lg:h-[22rem] rounded-full overflow-hidden border-2 shadow-2xl" style="border-color: var(--border);">
              <img src="/cristian.png" alt="Cristian Ornelas" class="w-full h-full object-cover" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Centered bouncing scroll chevron at bottom of hero -->
    <button id="scrollCue" type="button" aria-label="Scroll to next section" class="scroll-cue absolute left-1/2 -translate-x-1/2 bottom-8 md:bottom-10 cursor-pointer" style="background: transparent; border: none; color: var(--text-muted);" onclick="window.scrollBy({ top: window.innerHeight * 0.9, behavior: 'smooth' });">
      <svg class="scroll-chevron" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </button>
    <script is:inline>
      (function () {
        const cue = document.getElementById("scrollCue");
        if (!cue) return;
        const onScroll = () => {
          // Hide once the user has scrolled past ~half the hero
          if (window.scrollY > window.innerHeight * 0.4) {
            cue.classList.add("scroll-cue-hidden");
          } else {
            cue.classList.remove("scroll-cue-hidden");
          }
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      })();
    </script>
  </section>

  <!-- Stats -->
  <section class="py-12 md:py-20 transition-colors duration-300" style="background: var(--bg-secondary);">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
        {[
          { value: "5+", label: "Years in Security", color: "var(--accent)" },
          { value: "6", label: "Certifications", color: "var(--accent)" },
          { value: "3", label: "Companies", color: "var(--accent)" },
          { value: "5", label: "Career Roles", color: "var(--accent)" },
        ].map((stat, i) => (
          <div class={`reveal stagger-${i+1} p-4 md:p-5 rounded-2xl border text-center card-hover`} style="background: var(--card-bg); border-color: var(--border);">
            <span class="block text-xl md:text-2xl font-bold" style={`color: ${stat.color};`}>{stat.value}</span>
            <span class="block text-[13px] md:text-[15px] mt-1" style="color: var(--text-muted);">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Highlights -->
  <section class="py-14 md:py-24 transition-colors duration-300" style="background: var(--bg-primary);">
    <div class="max-w-7xl mx-auto px-6">
      <div class="reveal mb-6 md:mb-10">
        <span class="text-[13px] md:text-[15px] font-semibold tracking-[0.1em] uppercase" style="color: var(--accent);">Highlights</span>
        <h2 class="text-xl md:text-2xl font-bold mt-2" style="color: var(--text-primary);">What I Do</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-5">
        {[
          {
            icon: "lucide:code-xml",
            title: "Security Tooling & Automation",
            desc: "Engineer Python and serverless solutions that reduce manual security workflows from hours to minutes, building scalable AppSec infrastructure.",
            color: "var(--color-emerald)",
            bg: "var(--color-emerald-soft)",
          },
          {
            icon: "lucide:shield-alert",
            title: "Vulnerability Management",
            desc: "Build and operate vuln management pipelines at scale, from SAST/DAST in Kubernetes to bug bounty triage.",
            color: "var(--accent)",
            bg: "var(--accent-soft)",
          },
          {
            icon: "lucide:git-fork",
            title: "DevSecOps & Secure CI/CD",
            desc: "Embed security into CI/CD with Jenkins, GitHub Actions, and IaC, automating guardrails, secrets management, and secure deployments across cloud-native infrastructure.",
            color: "var(--color-yellow)",
            bg: "var(--color-yellow-soft)",
          },
          {
            icon: "lucide:shield",
            title: "Threat Modeling & Secure Design",
            desc: "Conduct secure design reviews on critical services and AI/ML features, applying an adversarial perspective to surface attack vectors early in the SDLC.",
            color: "var(--color-indigo)",
            bg: "var(--color-indigo-soft)",
          },
        ].map((item, i) => (
          <div class={`reveal stagger-${i+1} p-4 md:p-6 rounded-2xl border card-hover`} style="background: var(--card-bg); border-color: var(--border);">
            <div class="w-9 h-9 md:w-11 md:h-11 rounded-xl flex items-center justify-center mb-3 md:mb-4" style={`background: ${item.bg}; color: ${item.color};`}>
              <Icon name={item.icon} class="w-[18px] h-[18px] md:w-[22px] md:h-[22px]" />
            </div>
            <h3 class="text-[15px] md:text-base font-semibold mb-2" style="color: var(--text-primary);">{item.title}</h3>
            <p class="text-[13px] md:text-[15px] leading-relaxed" style="color: var(--text-secondary);">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech -->
  <section class="py-12 md:py-20 transition-colors duration-300" style="background: var(--bg-primary);">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="reveal text-[13px] md:text-[15px] font-semibold tracking-[0.1em] uppercase mb-4 md:mb-5" style="color: var(--accent);">Core Technologies</h2>
      <div class="reveal stagger-1 flex flex-wrap gap-1.5 md:gap-2">
        {["Python", "Go", "Bash", "AWS", "Terraform", "Docker", "Kubernetes", "Splunk", "Burpsuite", "Jenkins", "GitHub Actions", "Nmap"].map((t) => (
          <span class="text-[13px] md:text-[15px] px-2.5 md:px-3 py-1 md:py-1.5 rounded-lg border transition-colors duration-200 hover:border-[var(--accent)] hover:text-[var(--accent)]" style="border-color: var(--border); color: var(--text-secondary);">{t}</span>
        ))}
      </div>
    </div>
  </section>

  <style>
    /* Terminal-style hero summary */
    .terminal-window {
      background: #0D1117;
      border: 1px solid #30363D;
      border-radius: 10px;
      overflow: hidden;
      font-family: var(--font-mono);
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.25), 0 0 0 1px rgba(255, 159, 74, 0.04);
      position: relative;
    }
    /* Subtle CRT scanline overlay */
    .terminal-window::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: repeating-linear-gradient(
        0deg,
        rgba(255, 255, 255, 0.02) 0 1px,
        transparent 1px 3px
      );
      mix-blend-mode: overlay;
    }
    .terminal-bar {
      background: #161B22;
      padding: 9px 14px;
      display: flex;
      align-items: center;
      gap: 7px;
      border-bottom: 1px solid #30363D;
      position: relative;
    }
    .terminal-dot {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      display: inline-block;
    }
    .terminal-dot-red    { background: #FF5F56; }
    .terminal-dot-yellow { background: #FFBD2E; }
    .terminal-dot-green  { background: #27C93F; }
    .terminal-title {
      position: absolute;
      left: 0; right: 0;
      text-align: center;
      font-size: 14px;
      font-family: var(--font-mono);
      color: #8B949E;
      letter-spacing: 0.02em;
      pointer-events: none;
    }
    .terminal-body {
      padding: 20px 22px 22px;
      font-size: 15.5px;
      line-height: 1.75;
      color: #C9D1D9;
    }
    /* Mobile: shrink terminal so the whole hero fits in the viewport */
    @media (max-width: 767px) {
      .terminal-bar { padding: 7px 12px; }
      .terminal-title { font-size: 11.5px; }
      .terminal-dot { width: 10px; height: 10px; }
      .terminal-body {
        padding: 12px 14px 14px;
        font-size: 12.5px;
        line-height: 1.6;
      }
      .terminal-line { margin: 0 0 4px; }
    }
    .terminal-line {
      color: #C9D1D9;
      margin: 0 0 6px;
    }
    .terminal-prompt {
      color: var(--accent);
      font-weight: 700;
      margin-right: 10px;
    }
    .terminal-cmd {
      color: #F0F6FC;
    }
    .terminal-output {
      color: #B1BAC4;
      margin: 0;
    }
    .terminal-cursor {
      display: inline-block;
      color: #F0F6FC;
      margin-left: 4px;
      animation: terminal-blink 1.2s step-end infinite;
      transform: translateY(1px);
    }
    @keyframes terminal-blink {
      0%   { opacity: 1; }
      50%  { opacity: 0; }
      100% { opacity: 1; }
    }
    @media (prefers-reduced-motion: reduce) {
      .terminal-cursor { animation: none; }
    }

    /* Scroll cue — bouncing chevron at bottom of hero, appears after a delay */
    .scroll-cue {
      opacity: 0;
      transition: opacity 0.4s ease, visibility 0.4s ease, color 0.2s ease;
      animation: scroll-cue-appear 1.2s ease 8s forwards;
    }
    .scroll-cue:hover { color: var(--accent) !important; }
    .scroll-cue-hidden {
      opacity: 0 !important;
      visibility: hidden;
      pointer-events: none;
      animation: none !important;
    }
    .scroll-chevron {
      animation: chevron-bounce 1.8s ease-in-out infinite;
      animation-delay: 8s;
      opacity: 0;
    }
    @keyframes scroll-cue-appear {
      to { opacity: 1; }
    }
    @keyframes chevron-bounce {
      0%, 100% { transform: translateY(0); opacity: 0.7; }
      50%      { transform: translateY(6px); opacity: 1; }
    }
    @media (prefers-reduced-motion: reduce) {
      .scroll-cue { animation: scroll-cue-appear 0.3s ease 8s forwards; }
      .scroll-chevron { animation: none; opacity: 1; }
    }
  </style>
</Layout>
